# =============================================================
# BITCOIN BOT - Configuração
# Copie este arquivo para .env e preencha com seus dados reais
# =============================================================

# -------------------------------------------------------------
# GLASSNODE (opcional — deixar vazio para pular MVRV)
# Cadastro gratuito em: https://glassnode.com
# -------------------------------------------------------------
GLASSNODE_API_KEY=

# -------------------------------------------------------------
# TELEGRAM
# 1. Crie um bot em: https://t.me/BotFather  → /newbot
# 2. Descubra seu chat_id: envie /start para @userinfobot
# -------------------------------------------------------------
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# -------------------------------------------------------------
# EMAIL (Gmail)
# Pré-requisito: verificação em duas etapas ativa na conta Gmail
# Gere uma Senha de App em: https://myaccount.google.com/apppasswords
# Selecione: Outro (nome personalizado) → Bitcoin Bot
# -------------------------------------------------------------
EMAIL_ENABLED=false
GMAIL_SENDER=seu_email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_RECIPIENTS=destinatario@email.com

# -------------------------------------------------------------
# AGENDAMENTO
# -------------------------------------------------------------
# Intervalo em minutos entre cada verificação (padrão: 1440 = 24h)
# Para testes rápidos, use 1
CHECK_INTERVAL_MINUTES=1440
# Enviar resumo todo domingo às 09h mesmo sem sinal de compra
WEEKLY_STATUS_ENABLED=true

# -------------------------------------------------------------
# LIMIARES DE PONTUAÇÃO
# Sem MVRV: pontuação máxima = 60 pts (Fear&Greed 30 + MAs 30)
# Com MVRV: pontuação máxima = 100 pts → ajuste para 70 e 50
# -------------------------------------------------------------
SCORE_STRONG_BUY=45
SCORE_MODERATE_BUY=30

# -------------------------------------------------------------
# LOGGING
# -------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=bitcoin_bot.log
